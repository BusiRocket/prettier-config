{
  "name": "@vibracomet/prettier-config",
  "version": "0.1.0",
  "private": false,
  "packageManager": "pnpm@10.33.0",
  "license": "MIT",
  "description": "Shared Prettier configuration",
  "repository": {
    "type": "git",
    "url": "https://github.com/VibraComet/prettier-config.git"
  },
  "homepage": "https://github.com/VibraComet/prettier-config#readme",
  "bugs": {
    "url": "https://github.com/VibraComet/prettier-config/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "./base.mjs",
  "exports": {
    ".": "./base.mjs",
    "./frontend": "./frontend.mjs",
    "./astro": "./astro.mjs"
  },
  "scripts": {
    "fix": "prettier --write \"*.mjs\" --list-different",
    "format:check": "prettier --check \"*.mjs\""
  },
  "devDependencies": {
    "prettier": "^3.8.1"
  },
  "files": [
    "LICENSE",
    "README.md",
    "*.mjs"
  ],
  "peerDependencies": {
    "prettier": ">=3.0.0",
    "prettier-plugin-astro": ">=0.14.0",
    "prettier-plugin-css-order": ">=2.0.0",
    "prettier-plugin-organize-imports": ">=4.0.0",
    "prettier-plugin-tailwindcss": ">=0.6.0"
  },
  "peerDependenciesMeta": {
    "prettier-plugin-astro": {
      "optional": true
    },
    "prettier-plugin-tailwindcss": {
      "optional": true
    }
  }
}
